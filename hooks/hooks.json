{
  "hooks": {
    "TeammateIdle": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/validate-teammate-idle.sh",
            "timeout": 30,
            "statusMessage": "Checking teammate completion criteria..."
          }
        ]
      }
    ],
    "TaskCompleted": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "${CLAUDE_PLUGIN_ROOT}/scripts/validate-task-completion.sh",
            "timeout": 120,
            "statusMessage": "Validating task completion..."
          }
        ]
      }
    ]
  }
}
